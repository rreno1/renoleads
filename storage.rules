rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Property images: Public read access for web funnel viewers; write access restricted to authenticated owners
    match /properties/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Default catch-all
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
