rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Properties: Anyone can read published properties; authenticated owners have full access
    match /properties/{propertyId} {
      allow read: if resource.data.published == true || request.auth != null;
      allow write: if request.auth != null;
    }

    // Leads: Anyone can submit a new lead (status == 'new'); authenticated owners can read/update/delete
    match /leads/{leadId} {
      allow create: if request.resource.data.status == 'new';
      allow read, update, delete: if request.auth != null;
    }

    // Site Visits: Anyone can submit a site visit request along with a lead; authenticated owners can manage
    match /siteVisits/{visitId} {
      allow create: if request.resource.data.status == 'scheduled';
      allow read, update, delete: if request.auth != null;
    }

    // Users / Authorized Personnel: Restricted to authenticated users
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }

    // Device Tokens for FCM Notifications: Authenticated APK owners can write their device token
    match /deviceTokens/{tokenId} {
      allow read, write: if request.auth != null;
    }
  }
}
